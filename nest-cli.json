{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/managedepart/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/managedepart/tsconfig.app.json",
    "plugins": ["@nestjs/swagger"]
  },
  "monorepo": true,
  "root": "apps/managedepart",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "managedepart": {
      "type": "application",
      "root": "apps/managedepart",
      "entryFile": "main",
      "sourceRoot": "apps/managedepart/src",
      "compilerOptions": {
        "tsConfigPath": "apps/managedepart/tsconfig.app.json"
      }
    },
    "protection-orders": {
      "type": "application",
      "root": "apps/protection-orders",
      "entryFile": "main",
      "sourceRoot": "apps/protection-orders/src",
      "compilerOptions": {
        "tsConfigPath": "apps/protection-orders/tsconfig.app.json"
      }
    },
    "social-assistances": {
      "type": "application",
      "root": "apps/social-assistances",
      "entryFile": "main",
      "sourceRoot": "apps/social-assistances/src",
      "compilerOptions": {
        "tsConfigPath": "apps/social-assistances/tsconfig.app.json"
      }
    }
  }
}